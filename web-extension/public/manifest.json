{
  "name": "Ariadm Integration",
  "version": "1.0.0",
  "description": "Ariadm Integration Extension. Aria2c GUI built with SolidJS and TailwindCSS.",
  "manifest_version": 3,
  "permissions": ["downloads", "storage"],
  "host_permissions": ["http://localhost:9999/download"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "scripts": ["src/background.ts"]
  }
}
